# Flask configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_DEBUG=false

# Groq API Key (optional - fallback questions will be used if not provided)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Frontend URLs allowed to call this API (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Optional persistent SQLite path when DATABASE_URL is not set
SQLITE_PATH=interview_prep.db

# Optional managed database URL (Postgres on Render, Neon, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
